MONGO_URL=mongodb://localhost:27017
DB_NAME=githy
JWT_SECRET=change-me
ADMIN_EMAIL=admin@website.com
ADMIN_PASSWORD=Admin@777

# Production safety:
# - Leave SEED_POSTS_ON_STARTUP unset or false in production so deploys never
#   refill an empty database with demo content.
# - Leave STORE_UPLOADS_ON_DISK unset or false on hosted platforms and rely on
#   MongoDB-backed media persistence instead of ephemeral server files.
SEED_POSTS_ON_STARTUP=true
STORE_UPLOADS_ON_DISK=true
